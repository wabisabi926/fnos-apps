#!/bin/bash
# MoviePilot Docker app — wizard integration
# docker-compose.yaml declares \`env_file: [.env]\` so .env MUST exist when
# compose starts the container. We always write the file, with the wizard
# values or with empty values that let the compose-side defaults take over.

service_postinst() {
    local env_file="${TRIM_APPDEST}/docker/.env"

    # Always write .env (env_file directive in compose.yaml requires it).
    # SUPERUSER_PASSWORD must be supplied here (was previously via environment:
    # interpolation which silently lost wizard value because env_file does not
    # feed Compose-time interpolation). Default 'password' preserves original
    # behavior when wizard left blank.
    : > "$env_file"
    if [ -n "${wizard_media_dir}" ]; then
        apply_media_dir "${wizard_media_dir}"
        mkdir -p "${wizard_media_dir}" 2>/dev/null || true
    fi
    if [ -n "${wizard_download_dir}" ]; then
        apply_download_dir "${wizard_download_dir}"
        mkdir -p "${wizard_download_dir}" 2>/dev/null || true
    fi
    if [ -n "${wizard_password}" ]; then
        echo "SUPERUSER_PASSWORD=${wizard_password}" >> "$env_file"
    else
        echo "SUPERUSER_PASSWORD=password" >> "$env_file"
    fi
    chmod 600 "$env_file"
    install_log "Wrote docker .env (wizard values applied where supplied)"

    # Create default directories and fix ownership for PUID/PGID
    mkdir -p "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/core" "${TRIM_PKGVAR}/media" "${TRIM_PKGVAR}/downloads" 2>/dev/null || true
    chown -R "${TRIM_UID}:${TRIM_GID}" "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/core" "${TRIM_PKGVAR}/media" "${TRIM_PKGVAR}/downloads" 2>/dev/null || true
}

service_preupgrade() {
    if [ -f "${TRIM_APPDEST}/docker/.env" ]; then
        cp "${TRIM_APPDEST}/docker/.env" "${TRIM_PKGVAR}/.env.bak"
    fi
}

service_restore() {
    if [ -f "${TRIM_PKGVAR}/.env.bak" ]; then
        cp "${TRIM_PKGVAR}/.env.bak" "${TRIM_APPDEST}/docker/.env"
        rm -f "${TRIM_PKGVAR}/.env.bak"
    fi
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"
MEDIA_DIR_SAVE="${TRIM_PKGVAR}/.media_dir"
DOWNLOAD_DIR_SAVE="${TRIM_PKGVAR}/.download_dir"

# MEDIA_DIR / DOWNLOAD_DIR appear inside Compose's volumes: bindings, e.g.
#   - ${MEDIA_DIR:-${TRIM_PKGVAR:?}/media}:/media
# Volume substitutions are evaluated at compose parse time using shell env or
# cwd-discovered .env — NOT the env_file directive. So we sed-patch directly,
# mirroring ani-rss's approach for its download_dir.
apply_media_dir() {
    local dir="$1"
    [ -z "$dir" ] && return
    sed -i 's|^      - .*:/media$|      - '"${dir}"':/media|' "$COMPOSE_FILE"
    echo "${dir}" > "$MEDIA_DIR_SAVE"
    install_log "Patched docker-compose.yaml: media_dir=${dir}"
}

apply_download_dir() {
    local dir="$1"
    [ -z "$dir" ] && return
    sed -i 's|^      - .*:/downloads$|      - '"${dir}"':/downloads|' "$COMPOSE_FILE"
    echo "${dir}" > "$DOWNLOAD_DIR_SAVE"
    install_log "Patched docker-compose.yaml: download_dir=${dir}"
}

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:3000"/"'"${port}"':3000"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: port=${port}"
}

service_postupgrade() {
    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi
    if [ -f "$MEDIA_DIR_SAVE" ]; then
        apply_media_dir "$(cat "$MEDIA_DIR_SAVE")"
    fi
    if [ -f "$DOWNLOAD_DIR_SAVE" ]; then
        apply_download_dir "$(cat "$DOWNLOAD_DIR_SAVE")"
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
