#!/bin/bash
# MoviePilot Docker app — wizard integration
#
# fnOS reads docker-compose.yaml through Docker API directly; it does NOT
# invoke \`docker compose\` CLI, so \`env_file:\` and Compose-time interpolation
# of \`${VAR:-default}\` do not work for wizard-supplied values. We sed-patch
# the docker-compose.yaml in place for all wizard-driven values.

service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/core" "${TRIM_PKGVAR}/media" "${TRIM_PKGVAR}/downloads" 2>/dev/null || true
    chown -R "${TRIM_UID}:${TRIM_GID}" "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/core" "${TRIM_PKGVAR}/media" "${TRIM_PKGVAR}/downloads" 2>/dev/null || true

    if [ -n "${wizard_media_dir}" ]; then
        apply_media_dir "${wizard_media_dir}"
        mkdir -p "${wizard_media_dir}" 2>/dev/null || true
    fi
    if [ -n "${wizard_download_dir}" ]; then
        apply_download_dir "${wizard_download_dir}"
        mkdir -p "${wizard_download_dir}" 2>/dev/null || true
    fi
    if [ -n "${wizard_password}" ]; then
        apply_superuser_password "${wizard_password}"
    fi
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"
MEDIA_DIR_SAVE="${TRIM_PKGVAR}/.media_dir"
DOWNLOAD_DIR_SAVE="${TRIM_PKGVAR}/.download_dir"
SUPERUSER_PASSWORD_SAVE="${TRIM_PKGVAR}/.superuser_password"

# All wizard values get sed-patched into docker-compose.yaml directly.
apply_media_dir() {
    local dir="$1"
    [ -z "$dir" ] && return
    sed -i 's|^      - .*:/media$|      - '"${dir}"':/media|' "$COMPOSE_FILE"
    echo "${dir}" > "$MEDIA_DIR_SAVE"
    install_log "Patched docker-compose.yaml: media_dir=${dir}"
}

apply_download_dir() {
    local dir="$1"
    [ -z "$dir" ] && return
    sed -i 's|^      - .*:/downloads$|      - '"${dir}"':/downloads|' "$COMPOSE_FILE"
    echo "${dir}" > "$DOWNLOAD_DIR_SAVE"
    install_log "Patched docker-compose.yaml: download_dir=${dir}"
}

apply_superuser_password() {
    local pw="$1"
    [ -z "$pw" ] && return
    # Escape | for sed safety (passwords may contain it). Match the literal
    # SUPERUSER_PASSWORD line shipped in docker-compose.yaml.
    local escaped
    escaped=$(printf '%s' "$pw" | sed 's:[\\&|]:\\\\&:g')
    sed -i 's|^      - SUPERUSER_PASSWORD=.*|      - SUPERUSER_PASSWORD='"${escaped}"'|' "$COMPOSE_FILE"
    echo "${pw}" > "$SUPERUSER_PASSWORD_SAVE"
    chmod 600 "$SUPERUSER_PASSWORD_SAVE"
    install_log "Patched docker-compose.yaml: SUPERUSER_PASSWORD set (length=${#pw})"
}

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:3000"/"'"${port}"':3000"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: port=${port}"
}

service_postupgrade() {
    local env_file="${TRIM_APPDEST}/docker/.env"

    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi

    # MEDIA_DIR: prefer persisted save file; fall back to migrating from .env
    # for users upgrading from earlier broken revisions that wrote to .env only.
    if [ -f "$MEDIA_DIR_SAVE" ]; then
        apply_media_dir "$(cat "$MEDIA_DIR_SAVE")"
    elif [ -f "$env_file" ]; then
        local v
        v="$(grep -E '^MEDIA_DIR=' "$env_file" | head -1 | cut -d= -f2-)"
        if [ -n "$v" ]; then
            install_log "Migrating MEDIA_DIR from .env (legacy): $v"
            apply_media_dir "$v"
        fi
    fi

    if [ -f "$DOWNLOAD_DIR_SAVE" ]; then
        apply_download_dir "$(cat "$DOWNLOAD_DIR_SAVE")"
    elif [ -f "$env_file" ]; then
        local v
        v="$(grep -E '^DOWNLOAD_DIR=' "$env_file" | head -1 | cut -d= -f2-)"
        if [ -n "$v" ]; then
            install_log "Migrating DOWNLOAD_DIR from .env (legacy): $v"
            apply_download_dir "$v"
        fi
    fi

    if [ -f "$SUPERUSER_PASSWORD_SAVE" ]; then
        apply_superuser_password "$(cat "$SUPERUSER_PASSWORD_SAVE")"
    elif [ -f "$env_file" ]; then
        local v
        v="$(grep -E '^SUPERUSER_PASSWORD=' "$env_file" | head -1 | cut -d= -f2-)"
        if [ -n "$v" ] && [ "$v" != "password" ]; then
            install_log "Migrating SUPERUSER_PASSWORD from .env (legacy)"
            apply_superuser_password "$v"
        fi
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
