#!/bin/bash
# ANI-RSS Docker app — wizard integration

# NOTE: Do not pre-compute paths from TRIM_* at script source time.
# This file is sourced by `installer` BEFORE `load_variables_from_file`
# populates TRIM_APPDEST / TRIM_PKGVAR, so any top-level expansion would
# evaluate to a broken path like "/docker/docker-compose.yaml". Resolve
# the paths inside each function instead, so they expand at call time when
# the install variables have been loaded into the environment.

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    local compose_file="${TRIM_APPDEST}/docker/docker-compose.yaml"
    local port_save="${TRIM_PKGVAR}/.port"
    sed -i 's/"[^"]*:7789"/"'"${port}"':7789"/' "$compose_file"
    echo "${port}" > "$port_save"
    install_log "Patched docker-compose.yaml: port=${port}"
}

apply_download_dir() {
    local dir="$1"
    [ -z "$dir" ] && return
    local compose_file="${TRIM_APPDEST}/docker/docker-compose.yaml"
    local dir_save="${TRIM_PKGVAR}/.download_dir"
    sed -i 's|^      - .*:/downloads$|      - '"${dir}"':/downloads|' "$compose_file"
    echo "${dir}" > "$dir_save"
    install_log "Patched docker-compose.yaml: download_dir=${dir}"
}

service_postinst() {
    # Always write .env (env_file directive in compose.yaml requires it).
    # Missing wizard_download_dir leaves DOWNLOAD_DIR empty so the compose-side
    # default \`${DOWNLOAD_DIR:-${TRIM_PKGVAR:?}/downloads}\` still applies.
    local env_file="${TRIM_APPDEST}/docker/.env"
    : > "$env_file"
    if [ -n "${wizard_download_dir}" ]; then
        echo "DOWNLOAD_DIR=${wizard_download_dir}" >> "$env_file"
        apply_download_dir "${wizard_download_dir}"
        mkdir -p "${wizard_download_dir}" 2>/dev/null || true
        install_log "Wrote docker .env: DOWNLOAD_DIR=${wizard_download_dir}"
    else
        install_log "Wrote empty docker .env (using compose-side default)"
    fi
    mkdir -p "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/downloads" 2>/dev/null || true
    chown -R "${TRIM_UID}:${TRIM_GID}" "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/downloads" 2>/dev/null || true
}

service_preupgrade() {
    if [ -f "${TRIM_APPDEST}/docker/.env" ]; then
        cp "${TRIM_APPDEST}/docker/.env" "${TRIM_PKGVAR}/.env.bak"
    fi
}

service_restore() {
    if [ -f "${TRIM_PKGVAR}/.env.bak" ]; then
        cp "${TRIM_PKGVAR}/.env.bak" "${TRIM_APPDEST}/docker/.env"
        rm -f "${TRIM_PKGVAR}/.env.bak"
    fi
}

service_postupgrade() {
    local port_save="${TRIM_PKGVAR}/.port"
    local dir_save="${TRIM_PKGVAR}/.download_dir"
    if [ -f "$port_save" ]; then
        apply_port "$(cat "$port_save")"
    fi
    if [ -f "$dir_save" ]; then
        apply_download_dir "$(cat "$dir_save")"
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
