#!/bin/bash
# ZoneFoundry Bridge — wizard integration
#
# fnOS reads docker-compose.yaml via Docker API directly (no \`docker compose\`
# CLI), so env_file is ignored and \`${VAR:-default}\` is not interpolated for
# non-TRIM_ env vars. We sed-patch the environment: line in place.

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"
ZF_TOKEN_SAVE="${TRIM_PKGVAR}/.zf_token"

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    echo "${port}" > "$PORT_SAVE"
    install_log "Saved custom port: ${port}"
}

apply_zf_token() {
    local v="$1"
    [ -z "$v" ] && return
    local escaped
    escaped=$(printf '%s' "$v" | sed 's:[\\&|]:\\\\&:g')
    sed -i 's|^      - ZF_TOKEN=.*|      - ZF_TOKEN='"${escaped}"'|' "$COMPOSE_FILE"
    echo "${v}" > "$ZF_TOKEN_SAVE"
    chmod 600 "$ZF_TOKEN_SAVE"
    install_log "Patched docker-compose.yaml: ZF_TOKEN set"
}

service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/data" 2>/dev/null || true
    if [ -n "${wizard_token}" ]; then
        apply_zf_token "${wizard_token}"
    fi
}

service_postupgrade() {
    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi
    if [ -f "$ZF_TOKEN_SAVE" ]; then
        apply_zf_token "$(cat "$ZF_TOKEN_SAVE")"
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
