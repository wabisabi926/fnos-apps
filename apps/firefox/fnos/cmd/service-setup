#!/bin/bash

# Sanitize a wizard password into a value safe for .env / docker-compose.
# - strips ALL whitespace (newlines, tabs, spaces would break .env parsing)
# - removes characters that would be interpreted by docker-compose:
#     $ (env var expansion), " ' \` (quoting), # (comment), \ (escape)
# - truncates to 8 chars (VNC protocol hard limit; everything past is ignored)
# Returns empty string if nothing survives.
sanitize_vnc_password() {
    local raw="$1"
    # 1) strip newlines/tabs/spaces
    raw="${raw//[[:space:]]/}"
    # 2) keep only printable ASCII minus shell/dotenv-hostile characters
    local safe=""
    local i ch
    for (( i=0; i<${#raw} && i<8; i++ )); do
        ch="${raw:$i:1}"
        case "$ch" in
            [\$\"\'\`\#\\]) ;;
            *) safe="${safe}${ch}" ;;
        esac
    done
    printf '%s' "$safe"
}

service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/config" 2>/dev/null || true
    mkdir -p "${TRIM_PKGVAR}/fonts" 2>/dev/null || true

    # Write VNC password via .vncpass_clear file in the /config volume.
    # jlesage containers read this file on startup (preferred over env var).
    local clean=""
    if [ -n "${wizard_password}" ]; then
        clean="$(sanitize_vnc_password "${wizard_password}")"
        if [ -z "$clean" ]; then
            install_log "wizard_password contained only invalid characters; VNC auth NOT enabled"
        fi
    fi
    if [ -n "$clean" ]; then
        printf '%s' "$clean" > "${TRIM_PKGVAR}/config/.vncpass_clear"
        chmod 600 "${TRIM_PKGVAR}/config/.vncpass_clear"
        install_log "VNC password set via .vncpass_clear (length=${#clean})"
    else
        rm -f "${TRIM_PKGVAR}/config/.vncpass_clear"
        install_log "VNC password not set (no auth)"
    fi
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:5800"/"'"${port}"':5800"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: port=${port}"
}

service_postupgrade() {
    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
